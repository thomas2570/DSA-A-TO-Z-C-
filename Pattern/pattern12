
// Pattern/pattern12.cpp
// Print the following pattern for given N number of rows.
// For N = 5

// 0               0
// 0 1           1 0
// 0 1 2       2 1 0
// 0 1 2 3   3 2 1 0
// 0 1 2 3 4 4 3 2 1


#include<iostream>
using namespace std;
void pattern12(int n){
    int space = 2*(n-1);
    for(int i = 1; i < n; i++){
        for(int j = 0;j<=i;j++){
            cout<<j<<" ";
        }
        for(int j = 0;j<=space;j++){
            cout<<"  ";
        }
        for(int j = i;j>=1;j--){
            cout<<j<<" ";
        }
        space -= 2;
        cout<<endl;
    }
}
int main(){
    int n;
    cin>>n;
    pattern12(n);
}